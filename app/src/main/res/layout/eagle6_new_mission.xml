<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/e6_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:letterSpacing="0.1"
            android:text="@string/new_mission_title"
            android:textColor="@color/e6_blue"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Pilot -->
        <TextView style="@style/E6Label" android:text="@string/new_mission_pilot" />
        <Spinner android:id="@+id/spin_pilot" style="@style/E6Spinner"/>

        <!-- Platform -->
        <TextView style="@style/E6Label" android:text="@string/new_mission_platform" />
        <Spinner android:id="@+id/spin_platform" style="@style/E6Spinner"/>

        <!-- Mission type -->
        <TextView style="@style/E6Label" android:text="@string/new_mission_mission_type" />
        <Spinner android:id="@+id/spin_mission_type" style="@style/E6Spinner"/>

        <!-- Launch time -->
        <TextView style="@style/E6Label" android:text="@string/new_mission_launch_time" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txt_launch_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:textColor="@color/e6_text_primary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btn_pick_launch_time"
                style="@style/E6IconBtn"
                android:text="SET" />
        </LinearLayout>

        <!-- Launch location -->
        <TextView style="@style/E6Label" android:text="@string/new_mission_launch_location" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txt_launch_mgrs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:textColor="@color/e6_text_primary"
                android:textSize="16sp" />

            <Button android:id="@+id/btn_pick_launch" style="@style/E6IconBtn"
                android:text="@string/common_map" />
            <Button android:id="@+id/btn_reset_launch" style="@style/E6IconBtn"
                android:text="@string/common_self" />
        </LinearLayout>

        <!-- Infil waypoints -->
        <TextView style="@style/E6Label" android:text="@string/new_mission_infil_waypoints" />
        <LinearLayout
            android:id="@+id/infil_waypoints_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
        <Button
            android:id="@+id/btn_add_infil_waypoint"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/btn_secondary"
            android:text="@string/common_add_waypoint"
            android:textColor="@color/e6_text_secondary"
            android:textSize="14sp" />

        <!-- Activity location -->
        <TextView style="@style/E6Label" android:text="@string/new_mission_activity_location" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txt_activity_mgrs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:textColor="@color/e6_text_primary"
                android:textSize="16sp" />

            <Button android:id="@+id/btn_pick_activity" style="@style/E6IconBtn"
                android:text="@string/common_map" />
            <Button android:id="@+id/btn_reset_activity" style="@style/E6IconBtn"
                android:text="@string/common_self" />
        </LinearLayout>

        <!-- Exfil waypoints -->
        <TextView style="@style/E6Label" android:text="@string/new_mission_exfil_waypoints" />
        <LinearLayout
            android:id="@+id/exfil_waypoints_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
        <Button
            android:id="@+id/btn_add_exfil_waypoint"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/btn_secondary"
            android:text="@string/common_add_waypoint"
            android:textColor="@color/e6_text_secondary"
            android:textSize="14sp" />

        <!-- Recovery location -->
        <TextView style="@style/E6Label" android:text="@string/new_mission_recovery_location" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txt_recovery_mgrs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:textColor="@color/e6_text_primary"
                android:textSize="16sp" />

            <Button android:id="@+id/btn_pick_recovery" style="@style/E6IconBtn"
                android:text="@string/common_map" />
            <Button android:id="@+id/btn_reset_recovery" style="@style/E6IconBtn"
                android:text="@string/common_self" />
        </LinearLayout>

        <!-- Altitude -->
        <TextView style="@style/E6Label" android:text="@string/new_mission_altitude" />
        <Spinner android:id="@+id/spin_altitude" style="@style/E6Spinner"/>

        <!-- Duration -->
        <TextView style="@style/E6Label" android:text="@string/new_mission_duration" />
        <EditText
            android:id="@+id/edit_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@color/e6_divider"
            android:inputType="number"
            android:textColor="@color/e6_text_primary"
            android:textSize="16sp" />

        <!-- Confirm / Cancel -->
        <Button
            android:id="@+id/btn_confirm"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/btn_primary"
            android:text="@string/new_mission_confirm"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/btn_secondary"
            android:text="@string/new_mission_cancel"
            android:textColor="@color/e6_text_secondary"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
