<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/e6_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/e6_surface"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:letterSpacing="0.1"
            android:text="@string/missions_title"
            android:textColor="@color/e6_blue"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_new_mission"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/btn_primary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/missions_new_mission"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/btn_secondary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/missions_settings"
            android:textColor="@color/e6_text_secondary"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/e6_divider"/>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Active missions -->
            <TextView
                android:id="@+id/empty_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="32dp"
                android:text="@string/missions_empty"
                android:textColor="@color/e6_text_secondary"
                android:textSize="16sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/missions_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"/>

            <!-- History section (hidden when empty) -->
            <LinearLayout
                android:id="@+id/history_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/e6_divider"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/history_title"
                        android:textColor="@color/e6_text_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btn_clear_complete"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:text="@string/history_clear"
                        android:textSize="11sp"
                        android:background="@drawable/btn_secondary"
                        android:textColor="@color/e6_text_secondary"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/history_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="8dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
