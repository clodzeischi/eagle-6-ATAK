<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/e6_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/e6_surface"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/detail_action_back"
                android:textSize="12sp"
                android:background="@drawable/btn_secondary"
                android:textColor="@color/e6_text_secondary"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/detail_title"
                android:textColor="@color/e6_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/detail_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/e6_blue"
                android:background="@color/e6_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>
        </LinearLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Info rows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_label_pilot"
                    android:textColor="@color/e6_text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:id="@+id/detail_pilot"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/e6_text_primary"
                    android:textSize="14sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/e6_divider"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_label_platform"
                    android:textColor="@color/e6_text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:id="@+id/detail_platform"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/e6_text_primary"
                    android:textSize="14sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/e6_divider"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_label_type"
                    android:textColor="@color/e6_text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:id="@+id/detail_type"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/e6_text_primary"
                    android:textSize="14sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/e6_divider"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_label_activity"
                    android:textColor="@color/e6_text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:id="@+id/detail_activity_mgrs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/e6_text_primary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/e6_divider"
                android:layout_marginBottom="20dp"/>

            <!-- Primary action (MARK ON TASK) — LAUNCHING only -->
            <Button
                android:id="@+id/btn_primary_action"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:textColor="@android:color/white"
                android:visibility="gone"
                android:layout_marginBottom="10dp"/>

            <!-- Retask type row — ON_TASK only -->
            <LinearLayout
                android:id="@+id/row_retask_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp"
                android:visibility="gone">
                <Spinner
                    android:id="@+id/spin_retask_type"
                    style="@style/E6Spinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginBottom="0dp"/>
                <Button
                    android:id="@+id/btn_retask_type"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/detail_action_retask_type"
                    android:textSize="11sp"
                    android:background="@drawable/btn_secondary"
                    android:textColor="@color/e6_text_secondary"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Retask location — ON_TASK only -->
            <Button
                android:id="@+id/btn_retask_location"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="@string/detail_action_retask_location"
                android:textSize="12sp"
                android:background="@drawable/btn_secondary"
                android:textColor="@color/e6_text_secondary"
                android:visibility="gone"
                android:layout_marginBottom="10dp"/>

            <!-- RTH — ON_TASK only -->
            <Button
                android:id="@+id/btn_rth"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/detail_action_rth"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_warning"
                android:textColor="@android:color/white"
                android:visibility="gone"
                android:layout_marginBottom="10dp"/>

            <!-- Cancel — LAUNCHING ("CANCEL MISSION") and RTH ("CANCEL RTH") -->
            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:textSize="13sp"
                android:background="@drawable/btn_secondary"
                android:textColor="@color/e6_text_secondary"
                android:visibility="gone"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
