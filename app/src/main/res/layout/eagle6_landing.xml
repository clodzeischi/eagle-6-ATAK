<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/e6_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:letterSpacing="0.1"
            android:text="@string/landing_title"
            android:textColor="@color/e6_orange"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/landing_pilot_platform"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/e6_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="20dp"/>

        <!-- Recovery location -->
        <TextView
            style="@style/E6Label"
            android:text="@string/landing_recovery_point" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/txt_landing_mgrs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/e6_text_primary"
                android:textSize="13sp"
                android:fontFamily="monospace"/>

            <Button
                android:id="@+id/btn_pick_landing"
                style="@style/E6IconBtn"
                android:text="@string/common_map" />

            <Button
                android:id="@+id/btn_reset_landing"
                style="@style/E6IconBtn"
                android:text="@string/common_self" />
        </LinearLayout>

        <!-- RTH waypoints -->
        <TextView style="@style/E6Label" android:text="RTH WAYPOINTS (optional)"/>
        <LinearLayout
            android:id="@+id/landing_waypoints_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <Button
            android:id="@+id/btn_add_rtw_waypoint"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/btn_secondary"
            android:text="@string/common_add_waypoint"
            android:textColor="@color/e6_text_secondary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_land"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="LAND"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_warning"
            android:textColor="@android:color/white"/>

    </LinearLayout>
</ScrollView>
